{
  "name": "cinemaghar",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:fix": "eslint . --fix",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "dev:docker": "sh scripts/dev.sh",
    "prod:docker": "sh scripts/prod.sh",
    "prod:docker:down": "sh scripts/prod.sh down",
    "prod:docker:restart": "sh scripts/prod.sh restart",
    "prod:docker:logs": "sh scripts/prod.sh logs",
    "prod:docker:status": "sh scripts/prod.sh status",
    "db:seed": "node scripts/seed.js",
    "db:reset": "node scripts/db-reset.js",
    "db:reset:confirm": "node scripts/db-reset.js --confirm"
  },
  "type": "module",
  "keywords": [
    "cinema",
    "movies",
    "theater"
  ],
  "author": "Bishwash Chaudhari",
  "license": "ISC",
  "description": "A comprehensive platform for movie enthusiasts to explore, review, and discuss films.",
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.1",
    "winston": "^3.19.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "drizzle-kit": "^0.31.8",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.0",
    "supertest": "^7.2.2",
    "vitest": "^4.0.17"
  }
}
